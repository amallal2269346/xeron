# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://your-site.vercel.app

# ─── NOWPayments ─────────────────────────────────────────────────────────────
# Sign up at https://nowpayments.io → API Keys
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_key

# ─── EMAIL (Gmail recommended) ───────────────────────────────────────────────
# For Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Claude with Crypto <your@gmail.com>"

# ─── ADMIN ───────────────────────────────────────────────────────────────────
# Secret token to access /admin routes (change this!)
ADMIN_SECRET=change_this_to_something_secret_123
